{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@finance-ai/core": ["frontend/packages/core/src"],
      "@finance-ai/ui": ["frontend/packages/ui/src"],
      "@finance-ai/ui/*": ["frontend/packages/ui/src/*"],
      "@finance-ai/auth": ["frontend/packages/auth/src"],
      "@finance-ai/rbac": ["frontend/packages/rbac/src"],
      "@finance-ai/api-client": ["frontend/packages/api-client/src"],
      "@finance-ai/ap-hub": ["frontend/packages/ap-hub/src"],
      "@finance-ai/budget": ["frontend/packages/budget/src"],
      "@finance-ai/dashboard": ["frontend/packages/dashboard/src"],
      "@finance-ai/vendor": ["frontend/packages/vendor/src"],
      "@finance-ai/audit": ["frontend/packages/audit/src"],
      "@finance-ai/settings": ["frontend/packages/settings/src"]
    }
  },
  "include": ["frontend/**/*"],
  "exclude": ["node_modules", "dist"]
}